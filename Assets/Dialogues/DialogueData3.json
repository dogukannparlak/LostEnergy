{
    "lines": [
        { "speakerName": "Muhafız", "text": "Ah..." },
        { "speakerName": "Muhafız", "text": "Sonunda geldin." },

        { "speakerName": "Muhafız", "text": "Buraya kadar gelen pek olmaz." },

        { "speakerName": "Muhafız", "text": "Şimdi..." },
        { "speakerName": "Muhafız", "text": "Gerçeği öğrenme zamanı." },

        { "speakerName": "Muhafız", "text": "Burası bir dünya değil." },
        { "speakerName": "Muhafız", "text": "Yarım kalmış bir yaratım." },

        { "speakerName": "Muhafız", "text": "Tanrının denemesi." },
        { "speakerName": "Muhafız", "text": "Ama tamamlanamamış." },

        { "speakerName": "Muhafız", "text": "O yüzden her şey bozuk, çirkin ve orantısız." },
        { "speakerName": "Muhafız", "text": "O yüzden oksijen azalıyor." },
        { "speakerName": "Muhafız", "text": "O yüzden hiçlik var." },

        { "speakerName": "Muhafız", "text": "Bu yer silinmedi." },
        { "speakerName": "Muhafız", "text": "Ama düzeltilmedi de." },

        { "speakerName": "Muhafız", "text": "Sadece bırakıldı." },

        { "speakerName": "Muhafız", "text": "Kristaller..." },
        { "speakerName": "Muhafız", "text": "Onlar bu yerin sağlam inşa edilmiş yegane parçaları." },

        { "speakerName": "Muhafız", "text": "Gerçekliğin kırıntıları." },

        { "speakerName": "Muhafız", "text": "Topladıkça..." },
        { "speakerName": "Muhafız", "text": "Buradan koparsın." },

        { "speakerName": "Muhafız", "text": "Ve belki çıkarsın." },

        { "speakerName": "Muhafız", "text": "Ama çıkış..." },
        { "speakerName": "Muhafız", "text": "Gerçek mi bilmiyorum." },

        { "speakerName": "Muhafız", "text": "Belki başka bir deneme." },

        { "speakerName": "Muhafız", "text": "Ama burada kalmak..." },
        { "speakerName": "Muhafız", "text": "Onu biliyorum." },

        { "speakerName": "Muhafız", "text": "Burası çürüyor." },

        { "speakerName": "Muhafız", "text": "Ve evet..." },
        { "speakerName": "Muhafız", "text": "Bu bir döngü." },

        { "speakerName": "Muhafız", "text": "Sen daha önce de buradaydın." },
        { "speakerName": "Muhafız", "text": "Ama hatırlamıyorsun." },

        { "speakerName": "Muhafız", "text": "Ben hatırlıyorum." },

        { "speakerName": "Muhafız", "text": "Ben çıkamıyorum." },
        { "speakerName": "Muhafız", "text": "Ben bu yerin parçasıyım." },

        { "speakerName": "Muhafız", "text": "Ama sen..." },
        { "speakerName": "Muhafız", "text": "Henüz değilsin." },

        { "speakerName": "Muhafız", "text": "Seçimin var." },

        { "speakerName": "Muhafız", "text": "Devam et." },
        { "speakerName": "Muhafız", "text": "Ya da kal." },

        { "speakerName": "Muhafız", "text": "Ve unut." },


        { "speakerName": "Muhafız", "text": "..." },

        { "speakerName": "Muhafız", "text": "Kapılar orada." },

        { "speakerName": "Muhafız", "text": "Bu sefer son olabilir." },
        { "speakerName": "Muhafız", "text": "Ya da sadece başka bir başlangıç." },

        { "speakerName": "Muhafız", "text": "Bol şans." },
        { "speakerName": "Muhafız", "text": "Bu defa gerçekten ihtiyacın olacak." }
    ]
}

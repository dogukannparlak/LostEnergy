{
    "lines": [
        { "speakerName": "Muhafız", "text": "Hey..." },
        { "speakerName": "Muhafız", "text": "Yine sen." },

        { "speakerName": "Muhafız", "text": "Buraya kadar gelebildin demek." },
        { "speakerName": "Muhafız", "text": "İlk aşamayı geçtin." },

        { "speakerName": "Muhafız", "text": "Sana geçen sefer söylemeyi unutmuştum." },
        { "speakerName": "Muhafız", "text": "Ama fark etmişsindir." },

        { "speakerName": "Muhafız", "text": "Bazı bölgelerde oksijen daha hızlı bitiyor." },

        { "speakerName": "Muhafız", "text": "Neden mi?" },
        { "speakerName": "Muhafız", "text": "Çünkü bu yer... düzgün çalışmıyor." },

        { "speakerName": "Muhafız", "text": "Fark ettiysen, zeminleride kırmızı." },
        { "speakerName": "Muhafız", "text": "Bu iyiye işaret değil." },

        { "speakerName": "Muhafız", "text": "Oralar daha çok bozulmuş alanlar." },

        { "speakerName": "Muhafız", "text": "Tanrı yine bir şeyler denerken..." },
        { "speakerName": "Muhafız", "text": "Bir şeyleri bozmuş." },

        { "speakerName": "Muhafız", "text": "Fark etmişsindir..." },
        { "speakerName": "Muhafız", "text": "Şimdi de alanlar büyümüş." },

        { "speakerName": "Muhafız", "text": "Bu da bozulmanın yayıldığı anlamına geliyor." },

        { "speakerName": "Muhafız", "text": "Dikkatli ol." },

        { "speakerName": "Muhafız", "text": "Geri kalan şeyler aynı." },
        { "speakerName": "Muhafız", "text": "Hızlı ol." },
        { "speakerName": "Muhafız", "text": "Kristalleri topla." },
        { "speakerName": "Muhafız", "text": "Kapıya ulaş." },

        { "speakerName": "Muhafız", "text": "Bol şans." },
        { "speakerName": "Muhafız", "text": "Bu bölgede buna ihtiyacın olacak." },

        { "speakerName": "Muhafız", "text": "Bu ada..." },
        { "speakerName": "Muhafız", "text": "Hiç stabil sayılmaz." },

        { "speakerName": "Muhafız", "text": "Neyse..." },
        { "speakerName": "Muhafız", "text": "Fazla konuşmayayım." },

        { "speakerName": "Muhafız", "text": "Sağı solu belli olmuyor." },

        { "speakerName": "Muhafız", "text": "Galiba bu evrende yeni." },
        { "speakerName": "Muhafız", "text": "Her şeyi öğrenmeye çalışıyor." },
        { "speakerName": "Muhafız", "text": "Tıpkı yeni doğmuş bir bebek gibi." },

        { "speakerName": "Muhafız", "text": "Bu yüzden bu anomaliler." },

        { "speakerName": "Muhafız", "text": "Neyse..." },

        { "speakerName": "Muhafız", "text": "Bu bölgeyi geçersen..." },
        { "speakerName": "Muhafız", "text": "Yine karşılaşırız." },

        { "speakerName": "Muhafız", "text": "Tabii..." },
        { "speakerName": "Muhafız", "text": "Orası da varsa." },

        { "speakerName": "Muhafız", "text": "Görüşmek üzere." },

        { "speakerName": "Muhafız", "text": "Güç seninle olsun." },
        { "speakerName": "Muhafız", "text": "İhtiyacın olacak." }
    ]
}

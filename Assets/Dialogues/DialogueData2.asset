  m_Script: {fileID: 11500000, guid: 24c5e2c7e707edc4f898cc6a71343c33, type: 3}
  m_Name: DialogueData2
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speakerName: "Muhaf\u0131z"
    text: Hey...
  - speakerName: "Muhaf\u0131z"
    text: Yine sen.
  - speakerName: "Muhaf\u0131z"
    text: Buraya kadar gelebildin demek.
  - speakerName: "Muhaf\u0131z"
    text: "\u0130lk a\u015Famay\u0131 ge\xE7tin."
  - speakerName: "Muhaf\u0131z"
    text: "Sana ge\xE7en sefer s\xF6ylemeyi unutmu\u015Ftum."
  - speakerName: "Muhaf\u0131z"
    text: "Ama fark etmi\u015Fsindir."
  - speakerName: "Muhaf\u0131z"
    text: "Baz\u0131 b\xF6lgelerde oksijen daha h\u0131zl\u0131 bitiyor."
  - speakerName: "Muhaf\u0131z"
    text: Neden mi?
  - speakerName: "Muhaf\u0131z"
    text: "\xC7\xFCnk\xFC bu yer... d\xFCzg\xFCn \xE7al\u0131\u015Fm\u0131yor."
  - speakerName: "Muhaf\u0131z"
    text: "Fark ettiysen, zeminleride k\u0131rm\u0131z\u0131."
  - speakerName: "Muhaf\u0131z"
    text: "Bu iyiye i\u015Faret de\u011Fil."
  - speakerName: "Muhaf\u0131z"
    text: "Oralar daha \xE7ok bozulmu\u015F alanlar."
  - speakerName: "Muhaf\u0131z"
    text: "Tanr\u0131 yine bir \u015Feyler denerken..."
  - speakerName: "Muhaf\u0131z"
    text: "Bir \u015Feyleri bozmu\u015F."
  - speakerName: "Muhaf\u0131z"
    text: "Fark etmi\u015Fsindir..."
  - speakerName: "Muhaf\u0131z"
    text: "\u015Eimdi de alanlar b\xFCy\xFCm\xFC\u015F."
  - speakerName: "Muhaf\u0131z"
    text: "Bu da bozulman\u0131n yay\u0131ld\u0131\u011F\u0131 anlam\u0131na geliyor."
  - speakerName: "Muhaf\u0131z"
    text: Dikkatli ol.
  - speakerName: "Muhaf\u0131z"
    text: "Geri kalan \u015Feyler ayn\u0131."
  - speakerName: "Muhaf\u0131z"
    text: "H\u0131zl\u0131 ol."
  - speakerName: "Muhaf\u0131z"
    text: Kristalleri topla.
  - speakerName: "Muhaf\u0131z"
    text: "Kap\u0131ya ula\u015F."
  - speakerName: "Muhaf\u0131z"
    text: "Bol \u015Fans."
  - speakerName: "Muhaf\u0131z"
    text: "Bu b\xF6lgede buna ihtiyac\u0131n olacak."
  - speakerName: "Muhaf\u0131z"
    text: Bu ada...
  - speakerName: "Muhaf\u0131z"
    text: "Hi\xE7 stabil say\u0131lmaz."
  - speakerName: "Muhaf\u0131z"
    text: Neyse...
  - speakerName: "Muhaf\u0131z"
    text: "Fazla konu\u015Fmayay\u0131m."
  - speakerName: "Muhaf\u0131z"
    text: "Sa\u011F\u0131 solu belli olmuyor."
  - speakerName: "Muhaf\u0131z"
    text: Galiba bu evrende yeni.
  - speakerName: "Muhaf\u0131z"
    text: "Her \u015Feyi \xF6\u011Frenmeye \xE7al\u0131\u015F\u0131yor."
  - speakerName: "Muhaf\u0131z"
    text: "T\u0131pk\u0131 yeni do\u011Fmu\u015F bir bebek gibi."
  - speakerName: "Muhaf\u0131z"
    text: "Bu y\xFCzden bu anomaliler."
  - speakerName: "Muhaf\u0131z"
    text: Neyse...
  - speakerName: "Muhaf\u0131z"
    text: "Bu b\xF6lgeyi ge\xE7ersen..."
  - speakerName: "Muhaf\u0131z"
    text: "Yine kar\u015F\u0131la\u015F\u0131r\u0131z."
  - speakerName: "Muhaf\u0131z"
    text: Tabii...
  - speakerName: "Muhaf\u0131z"
    text: "Oras\u0131 da varsa."
  - speakerName: "Muhaf\u0131z"
    text: "G\xF6r\xFC\u015Fmek \xFCzere."
  - speakerName: "Muhaf\u0131z"
    text: "G\xFC\xE7 seninle olsun."
  - speakerName: "Muhaf\u0131z"
    text: "\u0130htiyac\u0131n olacak."

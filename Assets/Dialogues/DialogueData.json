{
    "lines": [
        { "speakerName": "Muhafız", "text": "Dur!" },
        { "speakerName": "Muhafız", "text": "Gitmeden önce bilmen gereken birkaç şey var." },

        { "speakerName": "Muhafız", "text": "Buraya nasıl geldin bilmiyorum." },
        { "speakerName": "Muhafız", "text": "Neden geldin onu da bilmiyorum." },
        { "speakerName": "Muhafız", "text": "Açıkçası umurumda da değil." },
        { "speakerName": "Muhafız", "text": "Ama gelmişsen..." },
        { "speakerName": "Muhafız", "text": "Tanrının bir bildiği vardır." },

        { "speakerName": "Muhafız", "text": "Benim görevim, bilmen gerekenleri anlatmak." },

        { "speakerName": "Muhafız", "text": "İlk olarak..." },
        { "speakerName": "Muhafız", "text": "Hiçliğin ortasında süzülen bir adadayız." },

        { "speakerName": "Muhafız", "text": "Ormanların içine girmeni pek tavsiye etmem." },
        { "speakerName": "Muhafız", "text": "Ada sınırına fazla yaklaşırsan..." },
        { "speakerName": "Muhafız", "text": "Hiçliğe düşersin." },

        { "speakerName": "Muhafız", "text": "Şimdi asıl konuya gelelim." },
        { "speakerName": "Muhafız", "text": "Kafanın üstünde gördüğün şey..." },
        { "speakerName": "Muhafız", "text": "O bir oksijen barı." },

        { "speakerName": "Muhafız", "text": "Bitmesini isteyeceğini sanmıyorum." },
        { "speakerName": "Muhafız", "text": "Ama denemek istersen..." },
        { "speakerName": "Muhafız", "text": "Sonuçlarını ben de merak ediyorum." },

        { "speakerName": "Muhafız", "text": "Çıkışa gidene kadar okları takip et." },

        { "speakerName": "Muhafız", "text": "Kristalleri toplamayı da unutma." },
        { "speakerName": "Muhafız", "text": "Onlar senin çıkış biletin." },
        { "speakerName": "Muhafız", "text": "Biraz da can verirler." },

        { "speakerName": "Muhafız", "text": "Tanrımızın garip huyları vardır." },
        { "speakerName": "Muhafız", "text": "Ama bazen insaflıdır." },

        { "speakerName": "Muhafız", "text": "Ee..." },
        { "speakerName": "Muhafız", "text": "Sormak istediğin bir şey var mı?" },

        { "speakerName": "Muhafız", "text": "..." },

        { "speakerName": "Muhafız", "text": "Ah..." },
        { "speakerName": "Muhafız", "text": "Siz konuşamıyorsunuz." },

        { "speakerName": "Muhafız", "text": "Unutuyorum bazen." },

        { "speakerName": "Muhafız", "text": "Bizim tek farkımız..." },
        { "speakerName": "Muhafız", "text": "Biraz daha fazla farkında olmamız." },

        { "speakerName": "Muhafız", "text": "Ama sonuçta..." },
        { "speakerName": "Muhafız", "text": "Aynı yerin parçalarıyız." },

        { "speakerName": "Muhafız", "text": "İleride daha çok şey öğreneceksin." },

        { "speakerName": "Muhafız", "text": "Dediklerimi unutma." },
        { "speakerName": "Muhafız", "text": "Bol şans, yabancı." }
    ]
}
